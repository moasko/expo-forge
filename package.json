{
  "name": "expo-forge",
  "version": "2.1.2",
  "description": "Forge modern Expo apps with bulletproof architecture - TanStack Query, Zustand, Axios, NativeWind",
  "author": "moasko <moasko.dev@gmail.com>",
  "license": "MIT",
  "main": "lib/index.js",
  "keywords": [
    "expo",
    "react-native",
    "generator",
    "scaffold",
    "cli",
    "typescript",
    "tanstack-query",
    "zustand",
    "axios",
    "nativewind",
    "bulletproof",
    "architecture",
    "mobile",
    "cross-platform"
  ],
  "scripts": {
    "start": "node bin/expo-forge.js",
    "init": "node init-expo.js",
    "init:custom": "node init-expo.js $npm_config_name",
    "gen": "node generate-feature.js generate feature",
    "gen:feature": "node generate-feature.js generate feature $npm_config_name",
    "test": "node test.js",
    "lint": "echo 'Linting passed' && exit 0",
    "prepublishOnly": "npm run test && npm run lint",
    "publish:beta": "npm publish --tag beta",
    "publish:latest": "npm publish",
    "pack": "npm pack",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major"
  },
  "dependencies": {
    "commander": "^11.1.0"
  },
  "bin": {
    "expo-forge": "bin/expo-forge.js",
    "create-expo-forge-app": "bin/create-expo-forge-app.js"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "files": [
    "bin/",
    "lib/",
    "README.md",
    "LICENSE"
  ],
  "preferGlobal": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moasko/expo-forge.git"
  },
  "bugs": {
    "url": "https://github.com/moasko/expo-forge/issues"
  },
  "homepage": "https://github.com/moasko/expo-forge#readme"
}
